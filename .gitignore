# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/blob-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# original, unoptimized source assets — keep locally, ship only the optimized version in public/
/assets-source

# Video Creator portfolio reel (3.5GB+, several files over GitHub's 100MB hard limit) — lives
# locally for dev preview only (mediaUrl() falls back to /public when NEXT_PUBLIC_MEDIA_BASE_URL
# is unset), real hosting is the separate Hetzner media server per docs/media-hosting.md.
/public/video-creator

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
