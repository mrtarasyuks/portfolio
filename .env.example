# Keep server-only secrets server-only — never prefix them with NEXT_PUBLIC_.

# Base URL for self-hosted case-study videos (Coolify + Caddy on Hetzner).
# See docs/media-hosting.md for setup. Leave empty to fall back to /public.
# Example: https://media.serhiitarasiuk.space
NEXT_PUBLIC_MEDIA_BASE_URL=

# Server-side only — powers the "ask about Serhii" chat widget (src/app/api/chat/route.ts).
# Get a key at https://console.anthropic.com/. Without it, the widget still renders but shows
# an error when a visitor sends a message.
ANTHROPIC_API_KEY=

# Server-side only — powers the voice-call feature (src/app/api/voice/session/route.ts).
# Get a key with Realtime access at https://platform.openai.com/. Without it, the call button
# still renders but shows a "not configured" error. Model name is overridable in case OpenAI
# renames/retires the default — check your own dashboard/docs for the current recommended model.
OPENAI_API_KEY=
OPENAI_REALTIME_MODEL=gpt-realtime-2.1

# Server-side only — verifies the anti-abuse challenge before a voice session is minted (a public
# button that starts a per-minute-billed API session is a real cost target). Create a widget at
# https://dash.cloudflare.com/?to=/:account/turnstile — the site key is public (ships to the
# browser), the secret key stays server-only.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Server-side only — lets the voice agent push a question it couldn't answer straight to Serhii's
# own Telegram (no database involved). Create a bot via @BotFather in Telegram to get the token;
# get your own chat_id by messaging @userinfobot (or the bot itself, then checking
# https://api.telegram.org/bot<token>/getUpdates).
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
