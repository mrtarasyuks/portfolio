# Keep server-only secrets server-only — never prefix them with NEXT_PUBLIC_.

# Base URL for self-hosted case-study videos (Coolify + Caddy on Hetzner).
# See docs/media-hosting.md for setup. Leave empty to fall back to /public.
# Example: https://media.serhiitarasiuk.space
NEXT_PUBLIC_MEDIA_BASE_URL=

# Server-side only — powers the "ask about Serhii" chat widget (src/app/api/chat/route.ts).
# Get a key at https://console.anthropic.com/. Without it, the widget still renders but shows
# an error when a visitor sends a message.
ANTHROPIC_API_KEY=
